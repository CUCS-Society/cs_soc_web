model Cabinet {
  id        String   @id @default(cuid())
  year      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentItem {
  id        String   @id @default(cuid())
  title     String
  content   String?  // Store as JSON string or use a relation for nested structures
  parentId  String?  // For nested items (e.g., children in your accordion)
  parent    DocumentItem? @relation("DocumentHierarchy", fields: [parentId], references: [id])
  children  DocumentItem[] @relation("DocumentHierarchy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}