model Cabinet {
  id        String     @id @default(cuid())
  year      String
  en_name   String?
  zh_name   String?
  documents Document[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Document {
  id           String    @id @default(cuid())
  cabinetId    String
  cabinet      Cabinet   @relation(fields: [cabinetId], references: [id])

  title        String
  description  String?
  category     String?   // e.g. "agenda", "minutes", "annual_report", "budget"
  documentUrl  String    // path or external URL
  fileType     String?   // e.g. "pdf", "doc", "docx"
  meetingNo    Int?      // e.g. 1, 2, 3...
  version      String?   // e.g. "v1", "v2"
  publishedAt  DateTime?
  sortOrder    Int?      // optional display ordering

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}